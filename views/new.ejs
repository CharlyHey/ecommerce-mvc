<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('partials/head') %>
    <title>Nuevo Producto</title>
</head>

<body>

  <%- include('partials/navbar') %>

    <div class="container">
      <h1 class="page-title">Nuevo Producto</h1>

      <% if (typeof error !=='undefined' ) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
        <% } %>

          <div class="card">
            <form action="/api/productos" method="POST">

              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" placeholder="Ej: Laptop Pro 15"
                  value="<%= typeof datos !== 'undefined' ? datos.nombre : '' %>" required>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="precio">Precio ($)</label>
                  <input type="number" id="precio" name="precio" placeholder="0.00" step="0.01" min="0"
                    value="<%= typeof datos !== 'undefined' ? datos.precio : '' %>" required>
                </div>
                <div class="form-group">
                  <label for="stock">Stock</label>
                  <input type="number" id="stock" name="stock" placeholder="0" min="0"
                    value="<%= typeof datos !== 'undefined' ? datos.stock : '' %>" required>
                </div>
              </div>

              <div class="form-group">
                <label for="categoria">Categoría</label>
                <select id="categoria" name="categoria" required>
                  <option value="" disabled selected>Selecciona una categoría</option>
                  <option value="electronica">Electrónica</option>
                  <option value="perifericos">Periféricos</option>
                  <option value="monitores">Monitores</option>
                  <option value="audio">Audio</option>
                </select>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-success">💾 Guardar Producto</button>
                <a href="/api/productos" class="btn btn-secondary">Cancelar</a>
              </div>

            </form>
          </div>
    </div>

</body>

</html>