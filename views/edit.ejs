<!DOCTYPE html>
<html lang="es">

<head>

  <%- include('partials/head') %>

  <title>
    Editar – <%= producto.nombre %>
  </title>

</head>

<body>

  <%- include('partials/navbar') %>

  <div class="container">

    <h1 class="page-title">
      Editar Producto
    </h1>

    <% if (typeof error !== 'undefined' && error) { %>

      <div class="alert alert-error">
        <%= error %>
      </div>

    <% } %>

    <div class="card">

      <form
        action="/api/productos/<%= producto.id %>?_method=PUT"
        method="POST"
        enctype="multipart/form-data"
      >

        <!-- Nombre -->

        <div class="form-group">

          <label for="nombre">
            Nombre
          </label>

          <input
            type="text"
            id="nombre"
            name="nombre"
            value="<%= producto.nombre %>"
            required
          >

        </div>

        <!-- Descripción -->

        <div class="form-group">

          <label for="descripcion">
            Descripción
          </label>

          <textarea
            id="descripcion"
            name="descripcion"
            rows="4"
            required
          ><%= producto.descripcion %></textarea>

        </div>

        <!-- Precio y Stock -->

        <div class="form-row">

          <div class="form-group">

            <label for="precio">
              Precio ($)
            </label>

            <input
              type="number"
              id="precio"
              name="precio"
              step="0.01"
              min="0"
              value="<%= producto.precio %>"
              required
            >

          </div>

          <div class="form-group">

            <label for="stock">
              Stock
            </label>

            <input
              type="number"
              id="stock"
              name="stock"
              min="0"
              value="<%= producto.stock %>"
              required
            >

          </div>

        </div>

        <!-- Categoría -->

        <div class="form-group">

          <label for="categoria">
            Categoría
          </label>

          <select
            id="categoria"
            name="categoria"
            required
          >

            <option
              value="laptops"
              <%= producto.categoria === 'laptops'
                ? 'selected'
                : '' %>
            >
              Laptops
            </option>

            <option
              value="monitores"
              <%= producto.categoria === 'monitores'
                ? 'selected'
                : '' %>
            >
              Monitores
            </option>

            <option
              value="audio"
              <%= producto.categoria === 'audio'
                ? 'selected'
                : '' %>
            >
              Audio
            </option>

            <option
              value="perifericos"
              <%= producto.categoria === 'perifericos'
                ? 'selected'
                : '' %>
            >
              Periféricos
            </option>

            <option
              value="gaming"
              <%= producto.categoria === 'gaming'
                ? 'selected'
                : '' %>
            >
              Gaming
            </option>

            <option
              value="smartphones"
              <%= producto.categoria === 'smartphones'
                ? 'selected'
                : '' %>
            >
              Smartphones
            </option>

          </select>

        </div>

        <!-- Imagen actual -->

        <% if (producto.imagen) { %>

          <div class="form-group">

            <label>
              Imagen actual
            </label>

            <div class="detail-image">

              <img
                src="<%= producto.imagen %>"
                alt="<%= producto.nombre %>"
              >

            </div>

          </div>

        <% } %>

        <!-- Nueva imagen -->

        <div class="form-group">

          <label for="imagen">
            Cambiar imagen
          </label>

          <input
            type="file"
            id="imagen"
            name="imagen"
            accept=".png,.jpg,.jpeg,.webp"
          >

        </div>

        <!-- Botones -->

        <div class="form-actions">

          <button
            type="submit"
            class="btn btn-primary"
          >

            ✏️ Actualizar

          </button>

          <a
            href="/api/productos/<%= producto.id %>"
            class="btn btn-secondary"
          >

            Cancelar

          </a>

        </div>

      </form>

    </div>

  </div>

</body>

</html>