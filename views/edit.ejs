<!DOCTYPE html>
<html lang="es">

<head>
  <%- include('partials/head') %>
    <title>Editar – <%= producto.nombre %>
    </title>
</head>

<body>

  <%- include('partials/navbar') %>

    <div class="container">
      <h1 class="page-title">Editar Producto</h1>

      <% if (typeof error !=='undefined' ) { %>
        <div class="alert alert-error">
          <%= error %>
        </div>
        <% } %>

          <div class="card">
            <form action="/api/productos/<%= producto.id %>?_method=PUT" method="POST">

              <div class="form-group">
                <label for="nombre">Nombre</label>
                <input type="text" id="nombre" name="nombre" value="<%= producto.nombre %>" required>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="precio">Precio ($)</label>
                  <input type="number" id="precio" name="precio" step="0.01" min="0" value="<%= producto.precio %>"
                    required>
                </div>
                <div class="form-group">
                  <label for="stock">Stock</label>
                  <input type="number" id="stock" name="stock" min="0" value="<%= producto.stock %>" required>
                </div>
              </div>

              <div class="form-group">
                <label for="categoria">Categoría</label>
                <select id="categoria" name="categoria" required>
                  <option value="electronica" <%=producto.categoria==='electronica' ? 'selected' : '' %>>Electrónica
                  </option>
                  <option value="perifericos" <%=producto.categoria==='perifericos' ? 'selected' : '' %>>Periféricos
                  </option>
                  <option value="monitores" <%=producto.categoria==='monitores' ? 'selected' : '' %>>Monitores</option>
                  <option value="audio" <%=producto.categoria==='audio' ? 'selected' : '' %>>Audio</option>
                </select>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn btn-primary">✏️ Actualizar</button>
                <a href="/api/productos/<%= producto.id %>" class="btn btn-secondary">Cancelar</a>
              </div>

            </form>
          </div>
    </div>

</body>

</html>