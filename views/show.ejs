<!DOCTYPE html>
<html lang="es">

<head>

  <%- include('partials/head') %>

  <title>
    <%= producto.nombre %>
  </title>

</head>

<body>

  <%- include('partials/navbar') %>

  <div class="container">

    <h1 class="page-title">
      Detalle del Producto
    </h1>

    <div class="detail-card">

      <!-- Imagen -->

      <div class="detail-image">

        <% if (producto.imagen) { %>

          <img
            src="<%= producto.imagen %>"
            alt="<%= producto.nombre %>"
          >

        <% } else { %>

          <img
            src="https://via.placeholder.com/700x400"
            alt="Sin imagen"
          >

        <% } %>

      </div>

      <!-- Información -->

      <div class="detail-header">

        <div>

          <h2 class="detail-title">
            <%= producto.nombre %>
          </h2>

          <p class="detail-id">
            ID #<%= producto.id %>
          </p>

        </div>

        <span class="product-category">
          <%= producto.categoria %>
        </span>

      </div>

      <!-- Precio -->

      <p class="product-price">

        $
        <%= producto.precio?.toLocaleString('es-MX') %>

      </p>

      <!-- Estado -->

      <p class="
        product-stock
        <%= producto.stock < 5 ? 'stock-low' : '' %>
      ">

        <% if (producto.stock > 0) { %>

          ✅ Disponible
          (<%= producto.stock %> unidades)

        <% } else { %>

          ❌ Agotado

        <% } %>

      </p>

      <!-- Descripción -->

      <div class="detail-description">

        <p>
          <%= producto.descripcion %>
        </p>

      </div>

      <!-- Acciones -->

      <div class="detail-actions">

        <!-- Carrito -->

        <% if (producto.stock > 0) { %>

          <form 
            action="/carrito/agregar/<%= producto.id %>"
            method="POST"
          >

            <button
              type="submit"
              class="btn btn-success"
            >

              🛒 Agregar al carrito

            </button>

          </form>

        <% } else { %>

          <button
            class="btn btn-delete"
            disabled
          >

            Producto agotado

          </button>

        <% } %>

        <!-- Editar -->

        <a
          href="/api/productos/<%= producto.id %>/editar"
          class="btn btn-edit"
        >

          ✏️ Editar

        </a>

        <!-- Eliminar -->

        <form
          action="/api/productos/<%= producto.id %>?_method=DELETE"
          method="POST"
          onsubmit="return confirm('¿Eliminar producto?')"
        >

          <button
            type="submit"
            class="btn btn-delete"
          >

            🗑️ Eliminar

          </button>

        </form>

        <!-- Volver -->

        <a
          href="/api/productos"
          class="btn btn-secondary"
        >

          ← Volver

        </a>

      </div>

    </div>

  </div>

</body>

</html>